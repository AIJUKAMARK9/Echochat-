LOCAL_MEDIA_URL_PREFIX=/media/
ENABLE_SAFETY_CHECK=true
DAILY_AI_LIMIT_PER_USER=200
JITSI_DOMAIN=meet.yourdomain.com
LOG_LEVEL=INFO
